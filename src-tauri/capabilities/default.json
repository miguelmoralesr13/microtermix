{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://*" },
        { "url": "https://*" },
        { "url": "http://**" },
        { "url": "https://**" },
        { "url": "http://10.57.113.51:9000/**" },
        { "url": "http://10.57.113.51/**" },
        { "url": "http://localhost:9000/**" }
      ]
    }
  ]
}